{
  "mcpServers": {
    "runninghub-image-gen": {
      "command": "uv",
      "args": [
        "--directory",
        "${workspaceFolder}/work/runninghub-image-gen",
        "run",
        "runninghub-image-gen"
      ],
      "env": {
        "RUNNINGHUB_API_KEY": "${RUNNINGHUB_API_KEY}"
      }
    }
  }
}